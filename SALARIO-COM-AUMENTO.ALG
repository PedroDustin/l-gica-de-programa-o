Algoritmo "salario-com-aumento"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi 
// Descriçăo   : algoritmo recebe salário e porcentagem de aumento, soma e exibe
//o resultado
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 20/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
salarioAtual: real
porcentagem: real
aumento: real
novoSalario: real
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva("Digite seu salário atual:")
leia(salarioAtual)
escreval("Digite a porcentagem do aumento")
leia(porcentagem)
aumento<- (salarioAtual * porcentagem) /100
escreval("seu aumento é:",aumento)
novoSalario<- aumento + salarioAtual
escreval("seu novo salário com o aumento é:",novoSalario:5:2)


Fimalgoritmo